class ProfileRow(Gtk.Box):
    def __init__(self, name, pcfg):
        super().__init__(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self.set_margin_top(8)
        self.set_margin_bottom(8)
        self.set_margin_start(12)
        self.set_margin_end(12)
        icon = Gtk.Image()
        icon.set_pixel_size(24)
        icon.set_from_icon_name("application-x-executable")
        matches = pcfg.get("match", [])
        if matches:
            icon_name = lookup_icon_name(matches[0])
            if icon_name:
                icon.set_from_icon_name(icon_name)
        self.append(icon)
        n = Gtk.Label(label=name, xalign=0)
        n.set_width_chars(14)
        n.set_css_classes(["heading"])
        self.append(n)
        rc = ", ".join(matches) if matches else "*"
        m = Gtk.Label(label=rc, xalign=0)
        m.set_hexpand(True)
        m.set_opacity(0.7)
        self.append(m)
        self.speed_label = Gtk.Label(label=f"{pcfg.get('speed', 0.0):+.2f}", xalign=1)
        self.speed_label.set_css_classes(["numeric"])
        self.append(self.speed_label)

