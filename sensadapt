import dbus, dbus.service
from dbus.mainloop.glib import DBusGMainLoop

SNW_BUS = "org.kde.StatusNotifierWatcher"
SNW_PATH = "/StatusNotifierWatcher"
SNW_IFACE = "org.kde.StatusNotifierWatcher"

SNI_IFACE = "org.kde.StatusNotifierItem"
DBUSMENU_IFACE = "com.canonical.dbusmenu"
DBUSMENU_PATH = "/com/canonical/DBusMenu"

class DBusMenu(dbus.service.Object):
    def __init__(self, conn, on_open, on_quit):
        self._revision = 0
        self.on_open = on_open
        self.on_quit = on_quit
        super().__init__(conn, DBUSMENU_PATH)

    @dbus.service.method(DBUSMENU_IFACE, in_signature="iis", out_signature="u(ia{sv}av)")
    def GetLayout(self, parent_id, depth, props):
        open_item = dbus.types.Struct([
            dbus.types.Int32(1),
            dbus.types.Dictionary({"label": "Open SensAdapt", "type": "standard", "enabled": True}, signature="sv"),
            dbus.types.Array([], signature="v"),
        ])
        quit_item = dbus.types.Struct([
            dbus.types.Int32(2),
            dbus.types.Dictionary({"label": "Quit", "type": "standard", "enabled": True}, signature="sv"),
            dbus.types.Array([], signature="v"),
        ])
        return (
            dbus.types.UInt32(self._revision),
            dbus.types.Struct([
                dbus.types.Int32(0),
                dbus.types.Dictionary({}, signature="sv"),
                dbus.types.Array([open_item, quit_item], signature="v"),
            ]),
        )

    @dbus.service.method(DBUSMENU_IFACE, in_signature="ai", out_signature="a(ia{sv})")
    def GetGroupProperties(self, ids):
        return []

    @dbus.service.method(DBUSMENU_IFACE, in_signature="isvu", out_signature="")
    def Event(self, item_id, event_id, data, timestamp):
        if event_id == "clicked":
            if item_id == 1:
                self.on_open()
            elif item_id == 2:
                self.on_quit()

class StatusNotifierItem(dbus.service.Object):
    _props = {
        "Category": "ApplicationStatus",
        "Id": "sensadapt",
        "Title": "SensAdapt",
        "Status": "Active",
        "IconName": "preferences-desktop-mouse",
        "IconThemePath": "",
        "ItemIsMenu": False,
        "Menu": dbus.ObjectPath(DBUSMENU_PATH),
    }

    def __init__(self, window, on_activate, on_quit):
        self._window = window
        self.on_activate = on_activate
        self.on_quit = on_quit
        self._id = f"org.sensadapt.tray.pid{os.getpid()}"
        bus = dbus.SessionBus()
        bus_name = dbus.service.BusName(self._id, bus)
        super().__init__(bus_name, "/StatusNotifierItem")
        self._menu = DBusMenu(bus, on_activate, on_quit)
        self._register()

    def _register(self):
        try:
            bus = dbus.SessionBus()
            obj = bus.get_object(SNW_BUS, SNW_PATH)
            iface = dbus.Interface(obj, SNW_IFACE)
            iface.RegisterStatusNotifierItem(self._id)
        except Exception:
            pass

    @dbus.service.method(SNI_IFACE, in_signature="ii", out_signature="")
    def Activate(self, x, y):
        self.on_activate()

    @dbus.service.method(SNI_IFACE, in_signature="ii", out_signature="")
    def ContextMenu(self, x, y):
        pass

    @dbus.service.method("org.freedesktop.DBus.Properties",
                         in_signature="ss", out_signature="v")
    def Get(self, interface, prop):
        if interface == SNI_IFACE and prop in self._props:
            return self._props[prop]
        raise dbus.exceptions.DBusException(
            "org.freedesktop.DBus.Error.InvalidArgs")

    @dbus.service.method("org.freedesktop.DBus.Properties",
                         in_signature="s", out_signature="a{sv}")
    def GetAll(self, interface):
        if interface == SNI_IFACE:
            return {k: v for k, v in self._props.items()}
        return {}

