CONFIG_PATH = Path.home() / ".config" / "sensadapt.json"
AUTOSTART_PATH = Path.home() / ".config" / "autostart" / "sensadapt.desktop"
SERVICE_NAME = "org.sensadapt.Switcher"
OBJECT_PATH = "/org/sensadapt/Switcher"

def qdbus(*args):
    try:
        raw = subprocess.run(["qdbus", *args], capture_output=True, text=True, timeout=2)
        return raw.stdout.strip() if raw.returncode == 0 else None
    except Exception:
        return None

def parse_info(raw):
    if not raw:
        return None
    info = {}
    for line in raw.split("\n"):
        if ":" in line:
            k, _, v = line.partition(":")
            info[k.strip()] = v.strip()
    return info

def get_active_window():
    return parse_info(qdbus("org.kde.KWin", "/KWin", "org.kde.KWin.queryWindowInfo"))

def list_devices():
    out = qdbus("org.kde.KWin")
    if not out:
        return []
    return [l.strip() for l in out.split("\n") if "InputDevice/event" in l]

def device_prop(path, prop):
    raw = qdbus("org.kde.KWin", path, "org.freedesktop.DBus.Properties.Get",
                "org.kde.KWin.InputDevice", prop)
    return raw.strip('"') if raw else None

def detect_mice():
    mice = []
    for path in list_devices():
        is_ptr = device_prop(path, "pointer")
        if is_ptr == "true":
            mice.append({"path": path, "name": device_prop(path, "name") or path})
    return mice

def load():
    if not CONFIG_PATH.exists():
        return {"profiles": {"default": {"speed": 0.8}}}
    with open(CONFIG_PATH) as f:
        return json.load(f)

def save(config):
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_PATH, "w") as f:
        json.dump(config, f, indent=2)

def lookup_icon_name(desktop_file):
    if not desktop_file:
        return None
    for d in ["/usr/share/applications", str(Path.home() / ".local/share/applications")]:
        path = Path(d) / f"{desktop_file}.desktop"
        if path.exists():
            with open(path) as f:
                for line in f:
                    if line.startswith("Icon="):
                        return line.strip().split("=", 1)[1]
    return None

def daemon_is_autostart():
    r = subprocess.run(["systemctl", "--user", "is-enabled", "sensadapt.service"],
                       capture_output=True, text=True, timeout=5)
    return r.stdout.strip() == "enabled"

def set_daemon_autostart(enabled):
    if enabled:
        subprocess.run(["systemctl", "--user", "enable", "--now", "sensadapt.service"],
                       capture_output=True, timeout=10)
    else:
        subprocess.run(["systemctl", "--user", "disable", "--now", "sensadapt.service"],
                       capture_output=True, timeout=10)

def gui_autostart_enabled():
    return AUTOSTART_PATH.exists()

def set_gui_autostart(enabled):
    if enabled:
        AUTOSTART_PATH.parent.mkdir(parents=True, exist_ok=True)
        with open(AUTOSTART_PATH, "w") as f:
            f.write(f"""[Desktop Entry]
Name=SensAdapt
Comment=Per-window mouse sensitivity profiles
Exec={Path.home() / ".local/bin/sensadapt"}
Icon=preferences-desktop-mouse
Terminal=false
Type=Application
Categories=Settings;HardwareSettings;
X-KDE-autostart-after=plasma-kwin_wayland.service
""")
    else:
        AUTOSTART_PATH.unlink(missing_ok=True)

def apply_theme(config):
    theme = config.get("theme", "system")
    style = Adw.StyleManager.get_default()
    if theme == "dark":
        style.set_color_scheme(Adw.ColorScheme.FORCE_DARK)
    elif theme == "light":
        style.set_color_scheme(Adw.ColorScheme.FORCE_LIGHT)
    else:
        style.set_color_scheme(Adw.ColorScheme.PREFER_LIGHT)

