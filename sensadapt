        self.set_modal(True)
        self.set_title("Edit Profile" if profile_name else "Add Profile")
        self.set_default_size(480, 320)
        self.config = config
        self.parent_win = parent
        self.profile_name = profile_name
        self.editing = profile_name is not None

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        vbox.set_margin_top(20)
        vbox.set_margin_bottom(20)
        vbox.set_margin_start(20)
        vbox.set_margin_end(20)
        self.set_child(vbox)

        self.name_entry = Gtk.Entry(placeholder_text="Profile name (e.g. overwatch)")
        self.name_entry.set_text(profile_name or "")
        vbox.append(self.name_entry)

        frame = Gtk.Frame(label="Application")
        app_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        app_box.set_margin_top(8)
        app_box.set_margin_bottom(8)
        app_box.set_margin_start(8)
        app_box.set_margin_end(8)
        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        cap_btn = Gtk.Button(label="Capture focused window")
        cap_btn.connect("clicked", self.on_capture)
        btn_row.append(cap_btn)
        browse_btn = Gtk.Button(label="Browse for .exe\u2026")
        browse_btn.connect("clicked", self.on_browse)
        btn_row.append(browse_btn)
        app_box.append(btn_row)
        self.icon_img = Gtk.Image()
        self.icon_img.set_pixel_size(32)
        app_box.append(self.icon_img)
        self.match_entry = Gtk.Entry(placeholder_text="Match (comma-separated)")
        if self.editing:
            p = config["profiles"].get(profile_name, {})
            self.match_entry.set_text(", ".join(p.get("match", [])))
        app_box.append(self.match_entry)
        self.cap_label = Gtk.Label(label="", xalign=0)
        app_box.append(self.cap_label)
        frame.set_child(app_box)
        vbox.append(frame)

        speed_frame = Gtk.Frame(label="Speed")
        speed_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        speed_box.set_margin_top(8)
        speed_box.set_margin_bottom(8)
        speed_box.set_margin_start(8)
        speed_box.set_margin_end(8)
        scale_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        scale_row.append(Gtk.Label(label="-1.0"))
        self.speed_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, -1.0, 1.0, 0.01)
        self.speed_scale.set_hexpand(True)
        self.speed_scale.set_draw_value(False)
        default_speed = config["profiles"].get(profile_name, {}).get("speed", 0.8) if profile_name else 0.8
        self.speed_scale.set_value(default_speed)
        scale_row.append(self.speed_scale)
        scale_row.append(Gtk.Label(label="1.0"))
        speed_box.append(scale_row)
        spin_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        spin_row.append(Gtk.Label(label="Value:"))
        self.speed_spin = Gtk.SpinButton.new_with_range(-5.0, 5.0, 0.01)
        self.speed_spin.set_value(default_speed)
        self.speed_spin.set_numeric(True)
        self.speed_spin.set_activates_default(True)
        self.speed_spin.set_width_chars(6)
        spin_row.append(self.speed_spin)
        speed_box.append(spin_row)
        speed_frame.set_child(speed_box)
        vbox.append(speed_frame)

        self.speed_scale.connect("value-changed", lambda s: self.speed_spin.set_value(s.get_value()))
        self.speed_spin.connect("value-changed", self.on_spin_changed)

        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8, halign=Gtk.Align.END)
        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.connect("clicked", lambda b: self.close())
        btn_box.append(cancel_btn)
        save_btn = Gtk.Button(label="Save")
        save_btn.add_css_class("suggested-action")
        save_btn.connect("clicked", self.on_save)
        btn_box.append(save_btn)
        vbox.append(btn_box)
        self.present()

    def on_spin_changed(self, spin):
        val = spin.get_value()
        if -1.0 <= val <= 1.0:
            self.speed_scale.set_value(val)

    def on_capture(self, btn):
        info = get_active_window()
        if not info or not info.get("resourceClass"):
            self.cap_label.set_label("No window focused"); return
        rc = info["resourceClass"]
        if rc.lower() in ("python3", "sensadapt", "mouse-profile-manager"):
            self.cap_label.set_label(f"Ignored: {rc} (manager itself)"); return
        self.match_entry.set_text(rc)
        self.cap_label.set_label(f"Detected: {rc}")
        icon_name = lookup_icon_name(info.get("desktopFile"))
        if icon_name:
            self.icon_img.set_from_icon_name(icon_name)
            self.icon_img.set_visible(True)
        if not self.name_entry.get_text():
            self.name_entry.set_text(rc)

    def on_browse(self, btn):
        dialog = Gtk.FileDialog.new()
        dialog.set_title("Select an executable")
        f = Gtk.FileFilter()
        f.add_suffix("exe")
        f.add_mime_type("application/x-ms-dos-executable")
        f.add_mime_type("application/x-executable")
        f.set_name("Executables")
        dialog.set_default_filter(f)
        dialog.open(None, None, self.on_browse_result, None)

    def on_browse_result(self, dialog, result, data):
        try:
            file = dialog.open_finish(result)
            if file:
                path = file.get_path()
                name = Path(path).stem
                self.match_entry.set_text(name)
                self.cap_label.set_label(f"Selected: {path}")
                if not self.name_entry.get_text():
                    self.name_entry.set_text(name)
        except GLib.GError:
            pass

    def on_save(self, btn):
        name = self.name_entry.get_text().strip()
        match_text = self.match_entry.get_text().strip()
        speed = self.speed_spin.get_value()
        if not name:
            self.cap_label.set_label("Name is required"); return
        matches = [m.strip() for m in match_text.split(",") if m.strip()]
        old_name = self.profile_name
        if old_name and old_name in self.config["profiles"]:
            del self.config["profiles"][old_name]
        self.config["profiles"][name] = {"speed": round(speed, 2)}
        if matches:
            self.config["profiles"][name]["match"] = matches
        save(self.config)
        self.parent_win.refresh()
        self.close()

