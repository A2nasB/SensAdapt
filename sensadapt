        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        vbox.append(device_row)
        vbox.append(toolbar)
        vbox.append(scrolled)
        vbox.append(self.speed_panel)
        self.set_child(vbox)

        self._updating = False
        self.populate_devices()
        self.device_dropdown.connect("notify::selected", self.on_device_changed)
        self.refresh()

        if self.config.get("minimize_to_tray", True):
            self.connect("close-request", self.on_close_request)
            self.setup_tray()
        else:
            self.connect("close-request", lambda w: False)

    def set_theme(self, theme):
        pass

    def setup_tray(self):
        if self.tray:
            return
        try:
            self.tray = StatusNotifierItem(self, self.present, self.quit_app)
        except Exception:
            self.tray = None

    def on_close_request(self, win):
        self.set_visible(False)
        return True

    def quit_app(self):
        self.get_application().quit()

    def refresh(self):
        self._updating = True
        self.config = load()
        while True:
            row = self.list.get_row_at_index(0)
            if not row:
                break
            self.list.remove(row)
        for name, pcfg in self.config.get("profiles", {}).items():
            row = Gtk.ListBoxRow()
            row.set_child(ProfileRow(name, pcfg))
            row._name = name
            self.list.append(row)
        n = len(self.config.get("profiles", {}))
        self.status_label.set_label(f"{n} profile{'s' if n != 1 else ''}")
        self.speed_panel.set_visible(False)
        self._updating = False

    def selected_name(self):
        row = self.list.get_selected_row()
        return row._name if row else None

    def populate_devices(self):
        while self.device_names.get_n_items():
            self.device_names.remove(0)
        self.device_paths = []
        mice = detect_mice()
        selected_idx = 0
        for i, m in enumerate(mice):
            self.device_names.append(m["name"])
            self.device_paths.append(m["path"])
            if m["path"] == self.config.get("device_path"):
                selected_idx = i
        self.device_dropdown.set_selected(selected_idx)

    def on_device_changed(self, dropdown, pspec):
        idx = dropdown.get_selected()
        if idx < 0 or idx >= len(self.device_paths):
            return
        self.config["device_path"] = self.device_paths[idx]
        self.config["device_name"] = self.device_names.get_string(idx)
        save(self.config)

    def on_select(self, lb, row):
        if self._updating or not row:
            self.speed_panel.set_visible(False) if not row else None
            return
        name = row._name
        p = self.config.get("profiles", {}).get(name, {})
        speed = p.get("speed", 0.8)
        matches = ", ".join(p.get("match", ["*"]))
        self.info_label.set_label(f"{name}  |  match: {matches}")
        self._updating = True
        self.inline_scale.set_value(speed)
        self.inline_spin.set_value(speed)
        self._updating = False
        self.speed_panel.set_visible(True)

    def on_inline_speed_change(self, scale):
        if self._updating:
            return
        val = scale.get_value()
        self._updating = True
        self.inline_spin.set_value(val)
        self._updating = False
        self.save_selected_speed(val)

    def on_inline_spin_change(self, spin):
        if self._updating:
            return
        val = spin.get_value()
        if -1.0 <= val <= 1.0:
            self._updating = True
            self.inline_scale.set_value(val)
            self._updating = False
        self.save_selected_speed(val)

    def save_selected_speed(self, val):
        name = self.selected_name()
        if not name:
            return
        self.config["profiles"][name]["speed"] = round(val, 2)
        save(self.config)
        row = self.list.get_selected_row()
        if row:
            child = row.get_child()
            if hasattr(child, 'speed_label'):
                child.speed_label.set_label(f"{val:+.2f}")
        self.status_label.set_label(f"{name}: {val:+.2f}")

    def on_add(self, btn):
        AddEditDialog(self, self.config)

    def on_edit(self, btn):
        name = self.selected_name()
        if name:
            AddEditDialog(self, self.config, profile_name=name)

    def on_delete(self, btn):
        name = self.selected_name()
        if not name or name == "default":
            return
        del self.config["profiles"][name]
        save(self.config)
        self.refresh()

    def on_settings(self, btn):
        SettingsDialog(self, self.config)

def main():
    dbus.mainloop.glib.DBusGMainLoop(set_as_default=True)
    app = Gtk.Application(application_id="org.sensadapt.manager")
    app.connect("activate", lambda a: ManagerWindow(a).present())
    app.run(sys.argv)

if __name__ == "__main__":
    main()
